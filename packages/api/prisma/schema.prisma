generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CustomGateway {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  color      String   @default("#6B5E5E")
  tiers      Json     @default("[]")
  pixTiers   Json     @default("[]") @map("pix_tiers")
  extraFixed Float    @default(0) @map("extra_fixed")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("custom_gateways")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

enum DeliveryStatus {
  PENDING
  PREPARING
  IN_TRANSIT
  DELIVERED
  RETURNED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AuditEntity {
  PRODUCT
  SALE
  USER
  FINANCE_ENTRY
  FINANCE_CATEGORY
}

enum FinanceType {
  PAYABLE
  RECEIVABLE
}

enum FinanceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  password            String
  isAdmin             Boolean  @default(false) @map("is_admin")
  roleId              String?  @map("role_id")
  permissionOverrides String[] @default([]) @map("permission_overrides")
  themeColors         Json?    @map("theme_colors")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  role                 Role?    @relation(fields: [roleId], references: [id])
  sales                Sale[]
  deliveryStatusChanges DeliveryStatusHistory[]
  auditLogs            AuditLog[]
  financeEntries       FinanceEntry[]

  @@map("users")
}

model Product {
  id            String  @id @default(cuid())
  name          String
  unitPrice     Float   @map("unit_price")
  quantity      Int     @default(0)
  supplier      String?
  imageUrl      String? @map("image_url")
  shippingCost  Float   @map("shipping_cost")
  desiredMargin Float   @default(20) @map("desired_margin")
  taxRate       Float   @default(0) @map("tax_rate")
  packagingCost Float   @default(0) @map("packaging_cost")
  laborCost     Float   @default(0) @map("labor_cost")
  otherCosts    Float   @default(0) @map("other_costs")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  saleItems SaleItem[]

  @@map("products")
}

model Sale {
  id               String         @id @default(cuid())
  gateway          String
  salePrice        Float          @map("sale_price")
  totalCost        Float          @map("total_cost")
  totalFees        Float          @map("total_fees")
  netRevenue       Float          @map("net_revenue")
  profit           Float
  customerName     String?        @map("customer_name")
  customerDocument String?        @map("customer_document")
  deliveryStatus   DeliveryStatus @default(PENDING) @map("delivery_status")
  trackingCode     String?        @map("tracking_code")
  importedFrom     String?        @map("imported_from")
  createdById      String         @map("created_by_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  items            SaleItem[]
  createdBy        User           @relation(fields: [createdById], references: [id])
  statusHistory    DeliveryStatusHistory[]

  @@index([gateway])
  @@index([deliveryStatus])
  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String  @map("sale_id")
  productId   String? @map("product_id")
  productName String  @default("") @map("product_name")
  quantity    Int
  salePrice   Float   @map("sale_price")
  unitCost    Float   @map("unit_cost")
  totalFees   Float   @map("total_fees")
  profit      Float

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model DeliveryStatusHistory {
  id          String         @id @default(cuid())
  saleId      String         @map("sale_id")
  fromStatus  DeliveryStatus @map("from_status")
  toStatus    DeliveryStatus @map("to_status")
  changedById String         @map("changed_by_id")
  changedAt   DateTime       @default(now()) @map("changed_at")

  sale      Sale @relation(fields: [saleId], references: [id])
  changedBy User @relation(fields: [changedById], references: [id])

  @@index([saleId])
  @@map("delivery_status_history")
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  action    AuditAction
  entity    AuditEntity
  entityId  String      @map("entity_id")
  oldData   Json?       @map("old_data")
  newData   Json?       @map("new_data")
  createdAt DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model FinanceCategory {
  id        String      @id @default(cuid())
  name      String
  type      FinanceType
  color     String      @default("#6B5E5E")
  icon      String      @default("Tag")
  isDefault Boolean     @default(false) @map("is_default")
  createdAt DateTime    @default(now()) @map("created_at")

  entries FinanceEntry[]

  @@map("finance_categories")
}

model FinanceEntry {
  id                String        @id @default(cuid())
  type              FinanceType
  title             String
  description       String?
  amount            Float
  categoryId        String        @map("category_id")
  dueDate           DateTime      @map("due_date")
  paidAt            DateTime?     @map("paid_at")
  status            FinanceStatus @default(PENDING)
  isRecurring       Boolean       @default(false) @map("is_recurring")
  recurringMonths   Int?          @map("recurring_months")
  recurringGroupId  String?       @map("recurring_group_id")
  installmentNumber Int?          @map("installment_number")
  createdById       String        @map("created_by_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  category  FinanceCategory @relation(fields: [categoryId], references: [id])
  createdBy User            @relation(fields: [createdById], references: [id])

  @@index([type])
  @@index([status])
  @@index([dueDate])
  @@index([categoryId])
  @@index([recurringGroupId])
  @@index([createdAt])
  @@map("finance_entries")
}
